@model List<RentalBike.Models.Bike>
@{
    ViewData["Title"] = "Керування велосипедами";
}

<h2>Керування велосипедами</h2>
<p><a asp-action="Create" class="btn btn-primary">Додати велосипед</a></p>

<table class="table table-bordered">
    <thead>
        <tr><th>Модель</th><th>Тип</th><th>Ціна</th><th>Колір</th><th>Доступний</th><th>Кількість</th><th>Дії</th></tr>
    </thead>
    <tbody>
        @foreach (var bike in Model)
        {
            <tr>
                <td>@bike.Model</td>
                <td>@bike.Type</td>
                <td>@bike.Price</td>
                <td>@bike.Color</td>
                <td>@(bike.IsAvailable ? "Так" : "Ні")</td>
                <td>@bike.Quantity</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@bike.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@bike.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>