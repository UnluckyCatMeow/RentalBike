@model List<RentalBike.Models.Bike>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Велосипеди";
}

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-12">
            <img src="/images/main_bike.jpg" alt="Велопрокат" class="img-fluid w-100 rounded" style="max-height: 150px; object-fit: cover;" onerror="this.onerror=null; this.src='/images/default-bike.jpg';">
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="info-block p-4 rounded shadow-sm text-center">
                <h3 class="mb-3">Вітаємо у нашому велосалоні!</h3>
                <p>
                    Ми команда, що любить велосипеди та свободу руху. У нас ви знайдете велосипеди різних типів та моделей - від міських до гірських,
                    від класичних до сучасних, а також дорослі і дитячі.
                </p>
                <p>
                    Наш сервіс створений для того, щоб кожен міг швидко та просто знайти свій ідеальний велосипед
                    та зручно забронювати його на потрібну годину.
                </p>
            </div>
        </div>
    </div>
    <!-- Фільтри -->
    <div class="row mb-4">
        <div class="col-md-12">
            <form method="get" class="row g-3" id="filterForm">
                <div class="col-md-4">
                    <input type="text" name="search" id="search" class="form-control" placeholder="Пошук за моделлю..." value="@ViewBag.CurrentSearch">
                </div>
                <div class="col-md-3">
                    <select name="type" id="type" class="form-select">
                        <option value="all">Всі типи</option>
                        @foreach (var t in ViewBag.Types)
                        {
                            if (t == ViewBag.CurrentType)
                            {
                                <option value="@t" selected>@t</option>
                            }
                            else
                            {
                                <option value="@t">@t</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="sort" id="sort" class="form-select">
                        <option value="">За назвою</option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc")">Ціна: низька → висока</option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc")">Ціна: висока → низька</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="button" id="filterBtn" class="btn btn-primary w-100">Фільтрувати</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Сітка велосипедів -->
    <div class="row" id="bikes-grid">
        @foreach (var bike in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm bike-card">
                    <img src="@(bike.ImageUrl ?? "/images/bike-placeholder.jpg")"
                         class="card-img-top"
                         alt="@bike.Model"
                         style="height: 180px; object-fit: scale-down;"
                         onerror="this.src='/images/bike-placeholder.jpg';">

                    <div class="card-body">
                        <h5 class="card-title">@bike.Model</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@bike.Type</h6>
                        <p><strong>Колір:</strong> @bike.Color</p>
                        <p><strong>Ціна:</strong> @bike.Price грн/год</p>
                        <p><strong>В наявності:</strong> @bike.Quantity шт.</p>

                        <!-- СТАТУС (кружечок + текст) -->
                        <div class="status-wrapper">
                            @if (bike.IsAvailable && bike.Quantity > 0)
                            {
                                <span class="status-dot available"></span>
                                <span class="status-text">Доступний</span>
                            }
                            else
                            {
                                <span class="status-dot unavailable"></span>
                                <span class="status-text">Тимчасово недоступний</span>
                            }
                        </div>

                        <!-- КНОПКА ОРЕНДИ-->
                        @if (bike.IsAvailable && bike.Quantity > 0)
                        {
                            @if (SignInManager.IsSignedIn(User))
                            {
                                <a href="@Url.Action("Rent", "Rental", new { id = bike.Id })" class="btn btn-primary rent-btn w-100 mt-3">Орендувати</a>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-primary rent-btn w-100 mt-3" onclick="openCustomModal()">Орендувати</button>
                            }
                        }
                        else
                        {
                            <button class="btn btn-secondary rent-btn w-100 mt-3" disabled>Недоступний</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Модальне вікно-->
<div id="customLoginModal" class="custom-modal">
    <div class="custom-modal-content">
        <div class="custom-modal-header">Потрібна авторизація</div>
        <div class="custom-modal-body">
            <p>Щоб орендувати велосипед, будь ласка, <strong>увійдіть</strong> або <strong>зареєструйтесь</strong>.</p>
            <div class="d-flex justify-content-center gap-2 mt-3">
                <a href="/Identity/Account/Login" class="btn btn-primary">Увійти</a>
                <a href="/Identity/Account/Register" class="btn btn-outline-primary">Зареєструватись</a>
            </div>
        </div>
        <div class="custom-modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeCustomModal()">Закрити</button>
        </div>
    </div>
</div>

<style>
    /* Стилі для карток */
    .bike-card {
        border-radius: 16px;
        overflow: hidden;
        transition: transform 0.2s;
    }

        .bike-card:hover {
            transform: translateY(-5px);
        }

    .status-wrapper {
        display: flex;
        align-items: center;
        gap: 6px;
        margin: 10px 0;
    }

    .status-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
    }

        .status-dot.available {
            background-color: #28a745;
            box-shadow: 0 0 0 2px rgba(40,167,69,0.2);
        }

        .status-dot.unavailable {
            background-color: #dc3545;
            box-shadow: 0 0 0 2px rgba(220,53,69,0.2);
        }

    .status-text {
        font-size: 0.85rem;
        color: #6c757d;
    }

    .rent-btn {
        border-radius: 30px !important;
        padding: 8px 16px;
        font-weight: 500;
    }
</style>

<script>
    function openCustomModal() {
        document.getElementById('customLoginModal').classList.add('show');
    }
    function closeCustomModal() {
        document.getElementById('customLoginModal').classList.remove('show');
    }

    // AJAX для фільтрів
    document.getElementById('filterBtn')?.addEventListener('click', function() {
        var search = document.getElementById('search').value;
        var type = document.getElementById('type').value;
        var sort = document.getElementById('sort').value;
        fetch(`/Bike/Index?search=${encodeURIComponent(search)}&type=${encodeURIComponent(type)}&sort=${encodeURIComponent(sort)}`)
            .then(response => response.text())
            .then(html => {
                var parser = new DOMParser();
                var doc = parser.parseFromString(html, 'text/html');
                var newGrid = doc.getElementById('bikes-grid');
                if (newGrid) document.getElementById('bikes-grid').innerHTML = newGrid.innerHTML;
            });
    });
</script>