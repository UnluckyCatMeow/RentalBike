@using Microsoft.AspNetCore.Identity
@using RentalBike.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" method="post" id="logoutForm">
        <ul>
            <li><a asp-area="Identity" asp-page="/Account/Manage/Index">Привет, @UserManager.GetUserName(User)!</a></li>
            <li><button type="submit">Выйти</button></li>
        </ul>
    </form>
}
else
{
    <ul>
        <li><a asp-area="Identity" asp-page="/Account/Register">Регистрация</a></li>
        <li><a asp-area="Identity" asp-page="/Account/Login">Войти</a></li>
    </ul>
}